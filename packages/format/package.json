{
  "name": "@session-link/format",
  "version": "0.1.0",
  "description": "The open session/v0 format for LLM sessions: types, JSON Schema, and validator.",
  "homepage": "https://session.link",
  "license": "MIT",
  "type": "module",
  "main": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.mjs"
    },
    "./schema": "./session.schema.json",
    "./validate": "./validate.mjs",
    "./secret-patterns": "./secret-patterns.mjs",
    "./run-summary": "./run-summary.mjs"
  },
  "files": [
    "index.mjs",
    "secret-patterns.json",
    "index.d.ts",
    "types.ts",
    "validate.mjs",
    "secret-patterns.mjs",
    "run-summary.mjs",
    "examples.mjs",
    "examples",
    "session.schema.json"
  ],
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "engines": {
    "node": "^18.20.0 || >=20.10.0"
  }
}
